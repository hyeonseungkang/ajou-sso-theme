{
  "name": "Modern Ajou SSO Theme",
  "version": "1.0",
  "description": "Apply modern Ajou SSO login page theme.",
  "manifest_version": 3,
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://sso.ajou.ac.kr/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
